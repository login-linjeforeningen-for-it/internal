[Unit]
Description=Deploy %i with git pull and docker compose
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-%h/.config/login-deploy/%i.env
TimeoutStartSec=900
ExecStart=/bin/bash -lc 'test -n "$REPO_PATH" && test -d "$REPO_PATH" && cd "$REPO_PATH" && git pull --ff-only origin ${DEPLOY_BRANCH:-main} && ${DEPLOY_COMPOSE_COMMAND:-docker compose up -d --build}'

[Install]
WantedBy=default.target
